{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "ExpenseApp",
    "Audience": "ExpenseAppClients",
    "SigningKey": "dev-signing-key-change-in-production",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 30
  },
  "Database": {
    "Provider": "Sqlite",
    "ConnectionStrings": {
      "SqlServer": "Server=localhost;Database=ExpenseDb;Trusted_Connection=True;TrustServerCertificate=True;",
      "Sqlite": "Data Source=app.db",
      "InMemory": "ExpenseInMemory"
    }
  },
  "Cors": {
    "Origins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "Uploads": {
    "MaxFileSizeBytes": 15728640,
    "MaxFileCount": 10,
    "AllowedContentTypes": ["image/jpeg", "image/png", "application/pdf"]
  }
}
